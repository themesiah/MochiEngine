Collisions.h\par \pard\plain 
{\tc\tcl2 \v Engine/src/Physics/Collisions.h}
{\xe \v Engine/src/Physics/Collisions.h}
{\bkmkstart AAAAAAAACC}
{\bkmkend AAAAAAAACC}
{
\par
\pard\plain \s40\li0\widctlpar\adjustright \shading1000\cbpat8 \f2\fs16\cgrid 1 {\cf21 #ifndef HDEF_COLLISIONS}\par
2 {\cf21 #define HDEF_COLLISIONS}\par
3 \par
4 {\cf21 #include "Shapes.h"}\par
5 {\cf21 #include "../Utils/MathUtils.h"}\par
6 \par
7 {\cf17 namespace }Mochi::Physics\par
8 \{\par
9     {\cf17 inline} {\cf18 bool} CollidesPointAndPoint({\cf17 const} Point &p1, {\cf17 const} Point &p2)\par
10     \{\par
11         {\cf19 return} p1.Position == p2.Position;\par
12     \}\par
13 \par
14     {\cf17 inline} {\cf18 bool} CollidesPointAndLine({\cf17 const} Point &p, {\cf17 const} Line &l)\par
15     \{\par
16         {\cf18 float} lineLength = (l.End - l.Position).Distance();\par
17         {\cf18 float} d1 = (p.Position - l.Position).Distance();\par
18         {\cf18 float} d2 = (p.Position - l.End).Distance();\par
19         {\cf19 return} Math::Approx(d1 + d2, lineLength);\par
20     \}\par
21 \par
22     {\cf17 inline} {\cf18 bool} CollidesPointAndCircle({\cf17 const} Point &p, {\cf17 const} Circle &c)\par
23     \{\par
24         {\cf19 return} (p.Position - c.Position).Distance() <= c.Radius;\par
25     \}\par
26 \par
27     {\cf17 inline} {\cf18 bool} CollidesPointAndRectangle({\cf17 const} Point &p, {\cf17 const} Rectangle &r)\par
28     \{\par
29         {\cf19 return} p.Position.x >= (r.Position.x - r.Extents.x) &&\par
30                p.Position.x <= (r.Position.x + r.Extents.x) &&\par
31                p.Position.y >= (r.Position.y - r.Extents.y) &&\par
32                p.Position.y <= (r.Position.y + r.Extents.y);\par
33     \}\par
34 \par
35     {\cf17 inline} {\cf18 bool} CollidesLineAndLine({\cf17 const} Line &l1, {\cf17 const} Line &l2)\par
36     \{\par
37         {\cf18 float} x1 = l1.Position.x;\par
38         {\cf18 float} x2 = l1.End.x;\par
39         {\cf18 float} x3 = l2.Position.x;\par
40         {\cf18 float} x4 = l2.End.x;\par
41         {\cf18 float} y1 = l1.Position.y;\par
42         {\cf18 float} y2 = l1.End.y;\par
43         {\cf18 float} y3 = l2.Position.y;\par
44         {\cf18 float} y4 = l2.End.y;\par
45         {\cf18 float} uA = ((x4 - x3) * (y1 - y3) - (y4 - y3) * (x1 - x3)) / ((y4 - y3) * (x2 - x1) - (x4 - x3) * (y2 - y1));\par
46         {\cf18 float} uB = ((x2 - x1) * (y1 - y3) - (y2 - y1) * (x1 - x3)) / ((y4 - y3) * (x2 - x1) - (x4 - x3) * (y2 - y1));\par
47         {\cf19 if} (uA >= 0 && uA <= 1 && uB >= 0 && uB <= 1)\par
48         \{\par
49             {\cf19 return} {\cf17 true};\par
50         \}\par
51         {\cf19 else}\par
52         \{\par
53             Point start(l1.Position);\par
54             Point end(l1.End);\par
55             {\cf19 return} l2.Collides(start) || l2.Collides(end);\par
56         \}\par
57     \}\par
58 \par
59     {\cf17 inline} {\cf18 bool} CollidesLineAndCircle({\cf17 const} Line &l, {\cf17 const} Circle &c)\par
60     \{\par
61         Point lStart = Point(l.Position);\par
62         Point lEnd = Point(l.End);\par
63         {\cf19 if} (c.Collides(lStart) || c.Collides(lEnd))\par
64             {\cf19 return} {\cf17 true};\par
65 \par
66         Vector2f lineVector = l.End - l.Position;\par
67         {\cf18 float} lineLength = lineVector.Distance();\par
68         {\cf18 float} dot = Vector2f::Dot(c.Position - l.Position, lineVector) / (lineLength * lineLength);\par
69         dot = Math::Clamp01(dot);\par
70         Point closestPoint = Point(l.Position + (lineVector * dot));\par
71         {\cf19 return} c.Collides(closestPoint);\par
72     \}\par
73 \par
74     {\cf17 inline} {\cf18 bool} CollidesLineAndRectangle({\cf17 const} Line &l, {\cf17 const} Rectangle &r)\par
75     \{\par
76         Line other = Line(r.Position + Vector2f(r.Extents.x, r.Extents.y), r.Position + Vector2f(r.Extents.x, -r.Extents.y));\par
77         {\cf19 if} (l.Collides(other))\par
78             {\cf19 return} {\cf17 true};\par
79         other = Line(r.Position + Vector2f(-r.Extents.x, r.Extents.y), r.Position + Vector2f(r.Extents.x, r.Extents.y));\par
80         {\cf19 if} (l.Collides(other))\par
81             {\cf19 return} {\cf17 true};\par
82         other = Line(r.Position + Vector2f(-r.Extents.x, r.Extents.y), r.Position + Vector2f(-r.Extents.x, -r.Extents.y));\par
83         {\cf19 if} (l.Collides(other))\par
84             {\cf19 return} {\cf17 true};\par
85         other = Line(r.Position + Vector2f(-r.Extents.x, -r.Extents.y), r.Position + Vector2f(r.Extents.x, -r.Extents.y));\par
86         {\cf19 if} (l.Collides(other))\par
87             {\cf19 return} {\cf17 true};\par
88 \par
89         {\cf19 return} {\cf17 false};\par
90     \}\par
91 \par
92     {\cf17 inline} {\cf18 bool} CollidesCircleAndCircle({\cf17 const} Circle &c1, {\cf17 const} Circle &c2)\par
93     \{\par
94         {\cf19 return} (c1.Position - c2.Position).Distance() < c1.Radius + c2.Radius;\par
95     \}\par
96 \par
97     {\cf17 inline} {\cf18 bool} CollidesCircleAndRectangle({\cf17 const} Circle &c, {\cf17 const} Rectangle &r)\par
98     \{\par
99         Vector2f test = c.Position;\par
100 \par
101         {\cf19 if} (c.Position.x < r.Position.x - r.Extents.x)\par
102             test.x = r.Position.x - r.Extents.x;\par
103         {\cf19 else} {\cf19 if} (c.Position.x > r.Position.x + r.Extents.x)\par
104             test.x = r.Position.x + r.Extents.x;\par
105 \par
106         {\cf19 if} (c.Position.y < r.Position.y - r.Extents.y)\par
107             test.y = r.Position.y - r.Extents.y;\par
108         {\cf19 else} {\cf19 if} (c.Position.y > r.Position.y + r.Extents.y)\par
109             test.y = r.Position.y + r.Extents.y;\par
110 \par
111         {\cf18 float} distance = (c.Position - test).Distance();\par
112         {\cf19 return} distance <= c.Radius;\par
113     \}\par
114 \par
115     {\cf17 inline} {\cf18 bool} CollidesRectangleAndRectangle({\cf17 const} Rectangle &r1, {\cf17 const} Rectangle &r2)\par
116     \{\par
117         {\cf19 return} (r1.Position.x + r1.Extents.x >= r2.Position.x - r2.Extents.x &&\par
118                 r1.Position.x - r1.Extents.x <= r2.Position.x + r2.Extents.x &&\par
119                 r1.Position.y + r1.Extents.y >= r2.Position.y - r2.Extents.y &&\par
120                 r1.Position.y - r1.Extents.y <= r2.Position.y + r2.Extents.y);\par
121     \}\par
122 \}\par
123 \par
124 {\cf21 #endif}\par
}
\par \pard\plain 

