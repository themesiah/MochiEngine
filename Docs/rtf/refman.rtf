6 {\cf21 #include <unordered_map>}\par
7 {\cf21 #include <iostream>}\par
8 {\cf21 #include <sstream>}\par
9 \par
10 {\cf17 namespace }Mochi::Debug\par
11 \{\par
12     {\cf17 class }FrameProfiler\par
13     \{\par
14     {\cf17 public}:\par
15         {\cf18 void} BeginSection({\cf17 const} std::string &name)\par
16         \{\par
17             mSections[name].start = std::chrono::high_resolution_clock::now();\par
18         \}\par
19 \par
20         {\cf18 void} EndSection({\cf17 const} std::string &name)\par
21         \{\par
22             {\cf17 auto} end = std::chrono::high_resolution_clock::now();\par
23             {\cf17 auto} &s = mSections[name];\par
24             s.accum += std::chrono::duration<double, std::milli>(end - s.start).count();\par
25         \}\par
26 \par
27         {\cf18 void} NewFrame()\par
28         \{\par
29             {\cf19 for} ({\cf17 auto} &[_, s] : mSections)\par
30                 s.accum = 0.0;\par
31         \}\par
32 \par
33         std::string Report(){\cf17  const}\par
34 {\cf17         }\{\par
35             {\cf18 double} total = 0.0;\par
36             {\cf19 for} ({\cf17 auto} &[name, s] : mSections)\par
37                 total += s.accum;\par
38 \par
39             std::stringstream ss;\par
40             ss << {\cf22 "START OF FRAME REPORT\\n"};\par
41             ss << {\cf22 "Frame "} << total << {\cf22 " ms\\n"};\par
42             {\cf19 for} ({\cf17 auto} &[name, s] : mSections)\par
43                 ss << name << {\cf22 ": "} << s.accum << {\cf22 "ms\\n"};\par
44             ss << {\cf22 "END OF FRAME REPORT\\n"};\par
45             {\cf19 return} ss.str();\par
46         \}\par
47 \par
48     {\cf17 private}:\par
49         {\cf17 struct }Section\par
50         \{\par
51             std::chrono::high_resolution_clock::time_point start;\par
52             {\cf18 double} accum = 0.0;\par
53         \};\par
54         std::unordered_map<std::string, Section> mSections;\par
55     \};\par
56 \}\par
57 \par
58 {\cf21 #endif}\par
}
\par \pard\plain 

