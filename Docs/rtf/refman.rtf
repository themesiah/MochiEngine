15     {\cf17 using }SubscriberPair = std::pair<SubscriptionHandler, SubscriberFunc>;\par
16     {\cf17 class }EventBus\par
17     \{\par
18     {\cf17 private}:\par
19         SubscriptionHandler mLastSubscriptionHandler;\par
20         std::vector<SubscriptionHandler> mFreeSubscriptionHandlers;\par
21         std::unordered_map<std::type_index, std::vector<SubscriberPair>> mSubscribersMap;\par
22 \par
23         SubscriptionHandler GetNextSubscriptionHandler()\par
24         \{\par
25             {\cf19 if} (mFreeSubscriptionHandlers.size() == 0)\par
26             \{\par
27                 {\cf19 return} mLastSubscriptionHandler++;\par
28             \}\par
29             {\cf19 else}\par
30             \{\par
31                 SubscriptionHandler free = mFreeSubscriptionHandlers.back();\par
32                 mFreeSubscriptionHandlers.pop_back();\par
33                 {\cf19 return} free;\par
34             \}\par
35         \}\par
36 \par
37     {\cf17 public}:\par
38         EventBus() : mLastSubscriptionHandler(1) \{\}\par
39         ~EventBus()\par
40         \{\par
41             mFreeSubscriptionHandlers.clear();\par
42             mSubscribersMap.clear();\par
43         \}\par
44 \par
45         {\cf17 template} <{\cf17 typename} EventType>\par
46         SubscriptionHandler Subscribe(std::function<{\cf18 void}({\cf17 const} EventType &)> callback)\par
47         \{\par
48             {\cf17 auto} &subscribers = mSubscribersMap[{\cf17 typeid}(EventType)];\par
49             {\cf17 auto} handler = GetNextSubscriptionHandler();\par
50             subscribers.emplace_back(handler, [callback]({\cf17 const} {\cf18 void} *e)\par
51                                      \{ callback(*{\cf17 static_cast<}{\cf17 const }EventType *{\cf17 >}(e)); \});\par
52             {\cf19 return} handler;\par
53         \}\par
54         {\cf17 template} <{\cf17 typename} EventType>\par
55         {\cf18 void} Unsubscribe(SubscriptionHandler handler)\par
56         \{\par
57             {\cf17 auto} it = mSubscribersMap.find({\cf17 typeid}(EventType));\par
58             {\cf19 if} (it == mSubscribersMap.end())\par
59                 {\cf19 return}; {\cf20 // There was not an event of that type}\par
60 \par
61             {\cf17 auto} &subscribers = it->second;\par
62             {\cf17 auto} was = subscribers.size();\par
63             subscribers.erase(\par
64                 std::remove_if(subscribers.begin(), subscribers.end(),\par
65                                [handler]({\cf17 auto} &pair)\par
66                                \{ return pair.first == handler; \}),\par
67                 subscribers.end());\par
68             {\cf19 if} (was != subscribers.size())\par
69                 mFreeSubscriptionHandlers.push_back(handler);\par
70         \}\par
71         {\cf17 template} <{\cf17 typename} EventType>\par
72         {\cf18 void} Publish({\cf17 const} EventType &event)\par
73         \{\par
74             {\cf17 auto} it = mSubscribersMap.find({\cf17 typeid}(EventType));\par
75             {\cf19 if} (it != mSubscribersMap.end())\par
76             \{\par
77                 {\cf19 for} ({\cf17 auto} &[{\cf18 id}, subscriber] : it->second)\par
78                 \{\par
79                     subscriber(&event);\par
80                 \}\par
81             \}\par
82         \}\par
83     \};\par
84 \}\par
85 \par
86 {\cf21 #endif}\par
}
\par \pard\plain 

